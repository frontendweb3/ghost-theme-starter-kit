{{!-- 
  Parameters:
  - href: (String) If provided, renders an <a> tag. If omitted, renders a <button>.
  - target: (String) Use "_blank" for external links.
  - variant: default, outline, secondary, ghost, destructive, link.
  - size: default, xs, sm, lg, icon, icon-xs, icon-sm, icon-lg.
  - class: (String) Additional custom CSS classes.
--}}

{{#if href}}
    <a href="{{href}}" 
       {{#if id}} id="{{id}}" {{/if}}
       {{#if name}} name="{{name}}"{{/if}} {{#if value}} value="{{value}}" {{/if}}
       {{#if ariaLabel}} aria-label="{{ariaLabel}}" {{/if}}
       {{#if target}}target="{{target}}" rel="noopener noreferrer"{{/if}}
       class="focus-visible:border-ring focus-visible:ring-ring/50 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive dark:aria-invalid:border-destructive/50 rounded-lg border border-transparent bg-clip-padding text-sm font-medium focus-visible:ring-3 aria-invalid:ring-3 [&_svg:not([class*='size-'])]:size-4 group/button inline-flex shrink-0 items-center justify-center whitespace-nowrap transition-all outline-none select-none disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg:not([class*='size-'])]:shrink-0
       {{!-- Variant Logic --}}
       {{#match variant "outline"}} border-border bg-background hover:bg-muted hover:text-foreground dark:bg-input/30 dark:border-input dark:hover:bg-input/50 aria-expanded:bg-muted aria-expanded:text-foreground
       {{else match variant "secondary"}} bg-secondary text-secondary-foreground hover:bg-secondary/80 aria-expanded:bg-secondary aria-expanded:text-secondary-foreground
       {{else match variant "ghost"}} hover:bg-muted hover:text-foreground dark:hover:bg-muted/50 aria-expanded:bg-muted aria-expanded:text-foreground
       {{else match variant "destructive"}} bg-destructive/10 hover:bg-destructive/20 focus-visible:ring-destructive/20 dark:focus-visible:ring-destructive/40 dark:bg-destructive/20 text-destructive focus-visible:border-destructive/40 dark:hover:bg-destructive/30
       {{else match variant "link"}} text-primary underline-offset-4 hover:underline
       {{else}} bg-primary text-primary-foreground [a]:hover:bg-primary/80
       {{/match}}
       {{!-- Size Logic --}}
       {{#match size "xs"}} h-6 gap-1 rounded-[min(var(--radius-md),10px)] px-2 text-xs in-data-[slot=button-group]:rounded-lg has-data-[icon=inline-end]:pr-1.5 has-data-[icon=inline-start]:pl-1.5 [&_svg:not([class*='size-'])]:size-3
       {{else match size "sm"}} h-7 gap-1 rounded-[min(var(--radius-md),12px)] px-2.5 text-[0.8rem] in-data-[slot=button-group]:rounded-lg has-data-[icon=inline-end]:pr-1.5 has-data-[icon=inline-start]:pl-1.5 [&_svg:not([class*='size-'])]:size-3.5
       {{else match size "lg"}} h-9 gap-1.5 px-2.5 has-data-[icon=inline-end]:pr-3 has-data-[icon=inline-start]:pl-3
       {{else match size "icon"}} size-8
       {{else match size "icon-xs"}} size-6 rounded-[min(var(--radius-md),10px)] in-data-[slot=button-group]:rounded-lg [&_svg:not([class*='size-'])]:size-3
       {{else match size "icon-sm"}} size-7 rounded-[min(var(--radius-md),12px)] in-data-[slot=button-group]:rounded-lg
       {{else match size "icon-lg"}} size-9
       {{else}} h-8 gap-1.5 px-2.5 has-data-[icon=inline-end]:pr-2 has-data-[icon=inline-start]:pl-2
       {{/match}}
       {{class}}">
        {{> @partial-block}}
    </a>
{{else}}
    {{#if debug}}
        {{log "[components/button]" "id:" id "ariaLabel:" ariaLabel "variant:" variant "size:" size "type:" type "class:" class "dataGhostSearch:" dataGhostSearch "data-ghost-search:" (lookup this "data-ghost-search")}}
    {{/if}}
    <button 
        {{#if dataGhostSearch}} data-ghost-search="true" {{/if}}
        {{#if id}} id="{{id}}" {{/if}}
        {{#if name}} name="{{name}}"{{/if}} {{#if value}} value="{{value}}" {{/if}}
        {{#if ariaLabel}} aria-label="{{ariaLabel}}" {{/if}}
        type="{{#if type}}{{type}}{{else}}button{{/if}}"
        class="focus-visible:border-ring focus-visible:ring-ring/50 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive dark:aria-invalid:border-destructive/50 border border-transparent bg-clip-padding text-sm font-medium focus-visible:ring-3 aria-invalid:ring-3 [&_svg:not([class*='size-'])]:size-4 group/button inline-flex shrink-0 items-center justify-center whitespace-nowrap transition-all outline-none select-none disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg:not([class*='size-'])]:shrink-0
        {{!-- Same Variant/Size Logic as above --}}
        {{#match variant "outline"}} border-border bg-background hover:bg-muted hover:text-foreground dark:bg-input/30 dark:border-input dark:hover:bg-input/50 aria-expanded:bg-muted aria-expanded:text-foreground
        {{else match variant "secondary"}} bg-secondary text-secondary-foreground hover:bg-secondary/80 aria-expanded:bg-secondary aria-expanded:text-secondary-foreground
        {{else match variant "ghost"}} hover:bg-muted hover:text-foreground dark:hover:bg-muted/50 aria-expanded:bg-muted aria-expanded:text-foreground
        {{else match variant "destructive"}} bg-destructive/10 hover:bg-destructive/20 focus-visible:ring-destructive/20 dark:focus-visible:ring-destructive/40 dark:bg-destructive/20 text-destructive focus-visible:border-destructive/40 dark:hover:bg-destructive/30
        {{else match variant "link"}} text-primary underline-offset-4 hover:underline
        {{else}} bg-primary text-primary-foreground [a]:hover:bg-primary/80
        {{/match}}
        {{#match size "xs"}} h-6 gap-1 rounded-[min(var(--radius-md),10px)] px-2 text-xs in-data-[slot=button-group]:rounded-lg has-data-[icon=inline-end]:pr-1.5 has-data-[icon=inline-start]:pl-1.5 [&_svg:not([class*='size-'])]:size-3
        {{else match size "sm"}} h-7 gap-1 rounded-[min(var(--radius-md),12px)] px-2.5 text-[0.8rem] in-data-[slot=button-group]:rounded-lg has-data-[icon=inline-end]:pr-1.5 has-data-[icon=inline-start]:pl-1.5 [&_svg:not([class*='size-'])]:size-3.5
        {{else match size "lg"}} h-9 gap-1.5 px-2.5 has-data-[icon=inline-end]:pr-3 has-data-[icon=inline-start]:pl-3
        {{else match size "icon"}} size-8
        {{else match size "icon-xs"}} size-6 rounded-[min(var(--radius-md),10px)] in-data-[slot=button-group]:rounded-lg [&_svg:not([class*='size-'])]:size-3
        {{else match size "icon-sm"}} size-7 rounded-[min(var(--radius-md),12px)] in-data-[slot=button-group]:rounded-lg
        {{else match size "icon-lg"}} size-9
        {{else match size "icon-full"}} size-9 rounded-full
        {{else}} h-8 gap-1.5 px-2.5 has-data-[icon=inline-end]:pr-2 has-data-[icon=inline-start]:pl-2
        {{/match}}
        {{class}}">
        {{> @partial-block}}
    </button>
{{/if}}